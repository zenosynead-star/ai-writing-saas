// AIライティングSaaS Prisma schema
// 要件定義書 11.3 に基づくデータモデル

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 実行時は pooler(PgBouncer) 経由でアイドル切断(E57P01)を回避。
  url       = env("DATABASE_URL")
  // マイグレーション/db push は直結が必要なため directUrl を分離。
  directUrl = env("DATABASE_URL_DIRECT")
}

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique // Free / Lite / Standard / Pro / Enterprise
  monthlyCredits  Int
  maxArticles     Int
  maxSites        Int
  maxRankKeywords Int
  maxImages       Int
  priceJpy        Int
  extraUnitJpy    Int      // 追加クレジット単価
  isActive        Boolean  @default(true)
  users           User[]
  subscriptions   Subscription[]
  createdAt       DateTime @default(now())
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String
  language            String   @default("ja")
  planId              String
  plan                Plan     @relation(fields: [planId], references: [id])
  currentCredits      Int      @default(0)
  referralCode        String   @unique
  referredByCode      String?
  emailVerifiedAt     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  subscriptions       Subscription[]
  creditTransactions  CreditTransaction[]
  sites               Site[]
  articles            Article[]
  images              GeneratedImage[]
  llmoBrands          LlmoBrand[]
  llmoPrompts         LlmoPrompt[]
  sessions            Session[]
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([userId])
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId        String
  plan          Plan     @relation(fields: [planId], references: [id])
  startedAt     DateTime @default(now())
  nextRenewalAt DateTime
  status        String   // active / canceled / past_due
  paymentMethod String?  // card / invoice
  createdAt     DateTime @default(now())

  @@index([userId])
}

model CreditTransaction {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Int      // 正: 付与 / 負: 消費
  balanceAfter      Int
  reason            String   // monthly_grant / consumption / purchase / refund
  relatedResourceId String?
  meta              String?  // JSON文字列で詳細
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

model Site {
  id                      String   @id @default(cuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain                  String
  type                    String   // own / competitor
  businessArea            String?
  searchConsoleConnected  Boolean  @default(false)
  createdAt               DateTime @default(now())
  articles                Article[]
  keywords                Keyword[]

  @@index([userId])
}

model Keyword {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keyword       String
  monthlyVolume Int?
  maxRank       Int      @default(100)
  frequency     String   @default("daily") // daily / weekly / monthly
  createdAt     DateTime @default(now())

  @@index([siteId])
}

model Article {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId      String?
  site        Site?    @relation(fields: [siteId], references: [id])
  title       String
  keywords    String   // JSON配列
  status      String   @default("draft") // draft / generating / completed / failed
  language    String   @default("ja")
  // ステップ間の中間ステート
  step        Int      @default(1)
  persona     String?
  searchIntent String?
  latentNeeds  String?  // JSON配列
  cooccurrenceWords String? // JSON配列: 競合分析で抽出した共起語（本文生成で再利用）
  toneSample   String?
  volumeSpec   String?  // 充実 / 指定なし / 簡潔
  customInstruction String?
  referenceInfo String? // 本文生成に渡す参考情報(独自の一次情報・社内データ等)
  useWebSearch Boolean @default(false) // 本文生成時に Web 検索で最新情報を注入するか
  pharmaCheckJson String? // 薬機法チェック結果(JSON)
  modelChoice  String?  // low_cost / balanced / high_quality (Step4で選択、Step5で使用)
  bodyHtml     String?
  metaDescription String?
  modelUsed    String?
  adviceJson   String?  // アドバイス機能の結果（要件5.6.3）
  // リライト機能（要件5.7）用フィールド
  sourceUrl    String?  // リライト元のURL
  originalBodyHtml String? // リライト元の本文HTML（差分表示用）
  rewriteMode  String?  // structure_preserve / restructure / partial
  // 画像生成・WordPress連携（要件6章・2.2）
  featuredImageId String?  // ArticleImage.id (アイキャッチ)
  featuredProductId String? // おすすめ商品ルールで選定した推奨商品 (products.json product_id)。本文/カードで使用
  wpPostId     Int?     // WordPressに投稿後のPost ID
  wpPostStatus String?  // draft / publish / future
  // 一括生成ジョブ（サーバー側キュー。画面更新で消えない＋停止/ストール時に自動再開）
  bulkJobId     String?   // BulkJob.id（このバルク実行に所属する生成対象記事）
  bulkState     String?   // pending / processing / done / failed / stopped（非バルクは null）
  bulkStage     String?   // 表示用の現在ステージ: '' / 本文 / 画像 / 公開
  bulkAttempts  Int       @default(0) // 試行回数（上限超で failed）
  bulkClaimedAt DateTime? // 処理開始時刻（古いままなら stall とみなし再実行）
  bulkNote      String?   // 表示用の注記/エラー（画像失敗・簡易内容など）
  bulkPub       String?   // WordPress公開結果ラベル（公開済み/下書き保存/薬機法保留/公開失敗…）
  bulkWpLink    String?   // 公開後の記事URL（表示用）
  totalCreditsUsed Int  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  headings     ArticleHeading[]
  articleImages ArticleImage[]

  @@index([userId, createdAt])
  @@index([bulkJobId])
  @@index([bulkState, bulkClaimedAt])
}

/// 一括生成ジョブ（サーバー側キュー）。クライアントは jobId で進捗をポーリングするので
/// 画面を更新/離脱しても状態が残る。停止フラグ＋ストール/失敗記事の自動再実行(watchdog timer)に使う。
model BulkJob {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("running") // running / done / stopped
  params    String   // JSON: model/useCompetitor/useWebSearch/effImageMode/wpPublish/targetChars/parallelism
  total     Int      @default(0)          // 生成対象記事数（skipped を除く）
  skipped   String?  // JSON: スキップ行（公開中KW）。画面再描画用に保持
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model ArticleHeading {
  id         String   @id @default(cuid())
  articleId  String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  level      Int      // 2..6
  text       String
  parentId   String?
  parent     ArticleHeading? @relation("HeadingTree", fields: [parentId], references: [id])
  children   ArticleHeading[] @relation("HeadingTree")
  order      Int
  bodyHtml   String?

  @@index([articleId])
}

model GeneratedImage {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId  String?
  prompt     String
  style      String?
  template   String?
  url        String?
  model      String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// 記事に紐づく画像（要件6章: アイキャッチ・h2見出し画像）
model ArticleImage {
  id         String   @id @default(cuid())
  articleId  String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  kind       String   // 'eyecatch' | 'h2'
  h2Index    Int?     // h2の何番目か (0始まり) (kind='h2'の時)
  mimeType   String   @default("image/png")
  dataBase64 String   // 画像のbase64
  prompt     String
  modelUsed  String?
  isPlaceholder Boolean @default(false) // プレースホルダー(つなぎ)画像か。後でバックフィルが本物のAI画像へ差し替える対象
  createdAt  DateTime @default(now())

  @@index([articleId])
}

// WordPress 連携設定（要件2.2: 記事の自動投稿）
model WpConnection {
  id               String   @id @default(cuid())
  userId           String
  siteUrl          String   // https://blog.example.com
  username         String
  appPassword      String   // Application Password
  defaultStatus    String   @default("draft")  // draft / publish / future
  isDefault        Boolean  @default(true)
  defaultProductId String?  // おすすめ商品ルールのデフォルト商品 (products.json の product_id)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  productRules     ProductRule[]

  @@index([userId])
}

/// サイト(WpConnection)単位の「おすすめ商品」出し分けルール。
/// keyword(部分一致) が記事のキーワード/タイトルに含まれれば productId を推奨商品にする。
/// order 昇順で最初に一致したものを採用。一致なしは WpConnection.defaultProductId。
model ProductRule {
  id             String       @id @default(cuid())
  wpConnectionId String
  wpConnection   WpConnection @relation(fields: [wpConnectionId], references: [id], onDelete: Cascade)
  order          Int          @default(0)
  keyword        String       // 含む文言 (部分一致・大文字小文字無視)
  productId      String       // products.json の product_id
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@index([wpConnectionId])
}

model LlmoBrand {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  aliases   String   // JSON配列
  domain    String?
  isOwn     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model LlmoPrompt {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptText String
  createdAt  DateTime @default(now())
  records    LlmoRecord[]

  @@index([userId])
}

model LlmoRecord {
  id           String   @id @default(cuid())
  promptId     String
  prompt       LlmoPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  date         DateTime
  aiService    String   // chatgpt / gemini / claude / perplexity / google_ai_overviews
  responseText String
  mentions     String   // JSON配列

  @@index([promptId, date])
}

// プロンプトテンプレートDB管理 (要件定義書 12.2)
model PromptTemplate {
  id           String   @id @default(cuid())
  name         String
  taskType     String   // title / heading / body / advice / image_prompt / llmo_parse / keyword
  language     String   @default("ja")
  targetModel  String   @default("any")
  templateText String
  variables    String?  // JSON
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, version])
  @@index([taskType, language, isActive])
}
