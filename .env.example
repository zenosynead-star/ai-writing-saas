# --- Database (Render Postgres / Neon等のPostgreSQL) ---
# 本番（Render）では render.yaml の fromDatabase で自動注入される
# ローカル開発時は Neon無料DB等の接続URLを設定
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# --- 認証 ---
# 本番では `openssl rand -hex 32` 等で生成した64桁以上のランダム文字列に必ず変更
JWT_SECRET="change-me-to-a-long-random-string"

# --- Google Gemini API（完全無料tier）---
# https://aistudio.google.com/ で発行（クレジットカード不要）
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL_HIGH="gemini-2.5-pro"
GEMINI_MODEL_BALANCED="gemini-2.5-flash"
GEMINI_MODEL_LOW="gemini-2.5-flash-lite"
