# --- Database (Vercel Postgres / Neon) ---
# Vercel ダッシュボード > Storage > Create > Postgres で作成すると自動で注入される
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
# Neon の場合は接続プーラー経由のURLとは別に、Prisma migrateには直結URLが必要
DIRECT_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# --- 認証 ---
# 本番では `openssl rand -hex 32` 等で生成した64桁以上のランダム文字列に必ず変更
JWT_SECRET="change-me-to-a-long-random-string"

# --- Anthropic Claude API ---
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL_HIGH="claude-opus-4-7"
ANTHROPIC_MODEL_BALANCED="claude-sonnet-4-6"
ANTHROPIC_MODEL_LOW="claude-haiku-4-5-20251001"
