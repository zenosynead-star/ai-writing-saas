# --- Database (Neon等のPostgreSQL) ---
# 実行時の接続URL。Neon では pooler(PgBouncer)エンドポイント(-pooler付き)を推奨
# （アイドル切断 E57P01 回避）。ローカルは直結URLでも可。
DATABASE_URL="postgresql://user:pass@host-pooler:5432/db?sslmode=require"
# マイグレーション/`prisma db push` 用の「直結」URL（prisma schema の directUrl が参照）。
# Neon では pooler を付けない直結エンドポイントを指定する。
# ※未設定だと `prisma db push`/`prisma migrate` が失敗する。pooler を使わない環境では
#   DATABASE_URL と同じ値でよい（ローカル開発など）。
DATABASE_URL_DIRECT="postgresql://user:pass@host:5432/db?sslmode=require"

# --- 認証 ---
# 本番では `openssl rand -hex 32` 等で生成した64桁以上のランダム文字列に必ず変更
JWT_SECRET="change-me-to-a-long-random-string"

# --- Google Gemini API（完全無料tier）---
# https://aistudio.google.com/ で発行（クレジットカード不要）
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL_HIGH="gemini-2.5-pro"
GEMINI_MODEL_BALANCED="gemini-2.5-flash"
GEMINI_MODEL_LOW="gemini-2.5-flash-lite"

# 競合分析用 Brave Search API
BRAVE_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
